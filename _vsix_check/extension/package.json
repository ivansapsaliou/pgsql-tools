{
	"name": "pgsql-tools",
	"displayName": "PostgreSQL Tools",
	"description": "PostgreSQL database management tool for VS Code",
	"version": "0.2.4",
	"publisher": "ivansapsaliou",
	"icon": "resources/icon.png",
	"engines": {
		"vscode": "^1.75.0"
	},
	"categories": [
		"Data Science"
	],
	"activationEvents": [],
	"main": "./out/extension.js",
	"contributes": {
		"configuration": {
			"title": "PostgreSQL Tools",
			"properties": {
				"pgsql-tools.gitRepositoryPath": {
					"type": "string",
					"default": "",
					"description": "Локальный каталог с DDL (Tables / Function / Procedures). Git-операции (commit/push) выполняются отдельно. При одинаковых именах в разных схемах используется один файл на имя."
				},
				"pgsql-tools.sqlObjectHighlighting": {
					"type": "boolean",
					"default": true,
					"description": "Подчёркивать распознанные таблицы, представления, функции и процедуры в SQL-редакторе."
				},
				"pgsql-tools.sqlObjectHoverDdl": {
					"type": "boolean",
					"default": true,
					"description": "Показывать DDL объекта во всплывающей подсказке при наведении."
				}
			}
		},
		"colors": [
			{
				"id": "pgsqlTools.tableUnderline",
				"description": "Подчёркивание таблиц в SQL",
				"defaults": {
					"dark": "#4FC1FF",
					"light": "#0078D4"
				}
			},
			{
				"id": "pgsqlTools.viewUnderline",
				"description": "Подчёркивание представлений в SQL",
				"defaults": {
					"dark": "#4EC9B0",
					"light": "#098658"
				}
			},
			{
				"id": "pgsqlTools.functionUnderline",
				"description": "Подчёркивание функций в SQL",
				"defaults": {
					"dark": "#DCDCAA",
					"light": "#795E26"
				}
			},
			{
				"id": "pgsqlTools.procedureUnderline",
				"description": "Подчёркивание процедур в SQL",
				"defaults": {
					"dark": "#C586C0",
					"light": "#811F3F"
				}
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "pgsql-tools",
					"title": "PostgreSQL Tools",
					"icon": "resources/database-icon.svg"
				}
			],
			"panel": [
				{
					"id": "pgsql-tools-panel",
					"title": "PostgreSQL",
					"icon": "resources/database-icon.svg"
				}
			]
		},
		"views": {
			"pgsql-tools": [
				{
					"id": "pgsqlDatabases",
					"name": "Databases",
					"when": "true"
				},
				{
					"type": "webview",
					"id": "pgsqlTreeSearch",
					"name": "Search",
					"when": "true",
					"visibility": "collapsed"
				}
			],
			"pgsql-tools-panel": [
				{
					"type": "webview",
					"id": "pgsqlResults",
					"name": "Query Results"
				}
			]
		},
		"commands": [
			{
				"command": "pgsql-tools.searchTree",
				"title": "PostgreSQL: Focus Tree Search",
				"icon": "$(search)"
			},
			{
				"command": "pgsql-tools.clearTreeSearch",
				"title": "PostgreSQL: Clear Tree Search",
				"icon": "$(close)"
			},
			{
				"command": "pgsql-tools.addConnection",
				"title": "PostgreSQL: Add Connection",
				"icon": "$(add)"
			},
			{
				"command": "pgsql-tools.openQueryEditor",
				"title": "PostgreSQL: Open Query Editor",
				"icon": "$(run)"
			},
			{
				"command": "pgsql-tools.executeSqlFile",
				"title": "PostgreSQL: Execute SQL (F9)",
				"icon": "$(play)"
			},
			{
				"command": "pgsql-tools.openQueryFile",
				"title": "PostgreSQL: Open Query File",
				"icon": "$(file)"
			},
			{
				"command": "pgsql-tools.viewTableDetails",
				"title": "PostgreSQL: View Table Details"
			},
			{
				"command": "pgsql-tools.editDDL",
				"title": "PostgreSQL: Edit DDL"
			},
			{
				"command": "pgsql-tools.refreshDatabases",
				"title": "PostgreSQL: Refresh",
				"icon": "$(refresh)"
			},
			{
				"command": "pgsql-tools.deleteConnection",
				"title": "PostgreSQL: Delete Connection",
				"icon": "$(trash)"
			},
			{
				"command": "pgsql-tools.selectConnection",
				"title": "PostgreSQL: Select Connection",
				"icon": "$(plug)"
			},
			{
				"command": "pgsql-tools.connectConnection",
				"title": "PostgreSQL: Connect",
				"icon": "$(debug-start)"
			},
			{
				"command": "pgsql-tools.disconnectConnection",
				"title": "PostgreSQL: Disconnect",
				"icon": "$(debug-stop)"
			},
			{
				"command": "pgsql-tools.schemaDiff",
				"title": "PostgreSQL: Schema Diff…",
				"icon": "$(diff)"
			},
			{
				"command": "pgsql-tools.showERD",
				"title": "PostgreSQL: Show ER Diagram",
				"icon": "$(type-hierarchy)"
			},
			{
				"command": "pgsql-tools.showHealth",
				"title": "PostgreSQL: Database Health",
				"icon": "$(pulse)"
			},
			{
				"command": "pgsql-tools.healthSlowQueries",
				"title": "PostgreSQL: Health — Slow Queries",
				"icon": "$(watch)"
			},
			{
				"command": "pgsql-tools.healthLocks",
				"title": "PostgreSQL: Health — Locks",
				"icon": "$(lock)"
			},
			{
				"command": "pgsql-tools.healthSizes",
				"title": "PostgreSQL: Health — Table & Index Sizes",
				"icon": "$(database)"
			},
			{
				"command": "pgsql-tools.healthVacuum",
				"title": "PostgreSQL: Health — Vacuum / Analyze",
				"icon": "$(symbol-misc)"
			},
			{
				"command": "pgsql-tools.explainQuery",
				"title": "PostgreSQL: Explain Query",
				"icon": "$(search)"
			},
			{
				"command": "pgsql-tools.showERDFromTable",
				"title": "PostgreSQL: Show ER Diagram from This Table",
				"icon": "$(type-hierarchy)"
			},
			{
				"command": "pgsql-tools.configureGitRepository",
				"title": "PostgreSQL: Git DDL Settings…",
				"icon": "$(folder-opened)"
			},
			{
				"command": "pgsql-tools.refreshGitStatus",
				"title": "PostgreSQL: Refresh Git DDL Status",
				"icon": "$(sync)"
			},
			{
				"command": "pgsql-tools.showGitDdlDiff",
				"title": "PostgreSQL: Compare with Git"
			},
			{
				"command": "pgsql-tools.gitCompareInSync",
				"title": "Сравнить с Git",
				"icon": "$(check)"
			},
			{
				"command": "pgsql-tools.gitCompareDiff",
				"title": "Сравнить с Git",
				"icon": "$(compare-changes)"
			},
			{
				"command": "pgsql-tools.gitCompareMissing",
				"title": "Сравнить с Git",
				"icon": "$(warning)"
			},
			{
				"command": "pgsql-tools.syncGitDdlFromDatabase",
				"title": "PostgreSQL: Sync DDL to Git File"
			}
		],
		"menus": {
			"editor/title": [
				{
					"command": "pgsql-tools.executeSqlFile",
					"when": "resourceLangId == sql",
					"group": "navigation"
				},
				{
					"command": "pgsql-tools.explainQuery",
					"when": "editorTextFocus && editorLangId == sql",
					"group": "navigation"
				}
			],
			"view/title": [
				{
					"command": "pgsql-tools.addConnection",
					"when": "view == pgsqlDatabases",
					"group": "navigation@1"
				},
				{
					"command": "pgsql-tools.refreshDatabases",
					"when": "view == pgsqlDatabases",
					"group": "navigation@2"
				},
				{
					"command": "pgsql-tools.openQueryFile",
					"when": "view == pgsqlDatabases",
					"group": "navigation@3"
				},
				{
					"command": "pgsql-tools.configureGitRepository",
					"when": "view == pgsqlDatabases",
					"group": "navigation@4"
				},
				{
					"command": "pgsql-tools.refreshGitStatus",
					"when": "view == pgsqlDatabases",
					"group": "navigation@5"
				}
			],
			"view/item/context": [
				{
					"command": "pgsql-tools.selectConnection",
					"when": "view == pgsqlDatabases && viewItem == connection",
					"group": "inline@1"
				},
				{
					"command": "pgsql-tools.disconnectConnection",
					"when": "view == pgsqlDatabases && viewItem == connection",
					"group": "inline@2"
				},
				{
					"command": "pgsql-tools.connectConnection",
					"when": "view == pgsqlDatabases && viewItem == connection_disconnected",
					"group": "inline@1"
				},
				{
					"command": "pgsql-tools.deleteConnection",
					"when": "view == pgsqlDatabases && viewItem == connection",
					"group": "inline@3"
				},
				{
					"command": "pgsql-tools.deleteConnection",
					"when": "view == pgsqlDatabases && viewItem == connection_disconnected",
					"group": "inline@2"
				},
				{
					"command": "pgsql-tools.showHealth",
					"when": "view == pgsqlDatabases && viewItem == connection",
					"group": "context@1"
				},
				{
					"command": "pgsql-tools.showERD",
					"when": "view == pgsqlDatabases && viewItem == connection",
					"group": "context@2"
				},
				{
					"command": "pgsql-tools.schemaDiff",
					"when": "view == pgsqlDatabases && viewItem == connection",
					"group": "context@3"
				},
				{
					"command": "pgsql-tools.showERDFromTable",
					"when": "view == pgsqlDatabases && (viewItem == table || viewItem == view || viewItem =~ /^table\\+git-/ || viewItem =~ /^view\\+git-/)",
					"group": "context@4"
				},
				{
					"command": "pgsql-tools.viewTableDetails",
					"when": "view == pgsqlDatabases && (viewItem == table || viewItem == view || viewItem == function || viewItem == procedure || viewItem =~ /^(table|view|function|procedure)\\+git-/)",
					"group": "context@5"
				},
				{
					"command": "pgsql-tools.editDDL",
					"when": "view == pgsqlDatabases && (viewItem == table || viewItem == view || viewItem == function || viewItem == procedure || viewItem =~ /^(table|view|function|procedure)\\+git-/)",
					"group": "context@6"
				},
				{
					"command": "pgsql-tools.gitCompareInSync",
					"when": "view == pgsqlDatabases && viewItem =~ /\\+git-in_sync$/",
					"group": "inline@90"
				},
				{
					"command": "pgsql-tools.gitCompareDiff",
					"when": "view == pgsqlDatabases && viewItem =~ /\\+git-diff$/",
					"group": "inline@90"
				},
				{
					"command": "pgsql-tools.gitCompareMissing",
					"when": "view == pgsqlDatabases && viewItem =~ /\\+git-missing_in_git$/",
					"group": "inline@90"
				},
				{
					"command": "pgsql-tools.showGitDdlDiff",
					"when": "view == pgsqlDatabases && (viewItem == table || viewItem == function || viewItem == procedure || viewItem =~ /^(table|function|procedure)\\+git-/)",
					"group": "context@7"
				},
				{
					"command": "pgsql-tools.syncGitDdlFromDatabase",
					"when": "view == pgsqlDatabases && (viewItem == table || viewItem == function || viewItem == procedure || viewItem =~ /^(table|function|procedure)\\+git-/)",
					"group": "context@8"
				}
			],
			"commandPalette": [
				{
					"command": "pgsql-tools.searchTree",
					"when": "pgsqlToolsActive"
				},
				{
					"command": "pgsql-tools.clearTreeSearch",
					"when": "pgsqlToolsActive"
				},
				{
					"command": "pgsql-tools.showHealth",
					"when": "pgsqlToolsActive"
				},
				{
					"command": "pgsql-tools.schemaDiff",
					"when": "pgsqlToolsActive"
				},
				{
					"command": "pgsql-tools.showERD",
					"when": "pgsqlToolsActive"
				},
				{
					"command": "pgsql-tools.healthSlowQueries",
					"when": "pgsqlToolsActive"
				},
				{
					"command": "pgsql-tools.healthLocks",
					"when": "pgsqlToolsActive"
				},
				{
					"command": "pgsql-tools.healthSizes",
					"when": "pgsqlToolsActive"
				},
				{
					"command": "pgsql-tools.healthVacuum",
					"when": "pgsqlToolsActive"
				},
				{
					"command": "pgsql-tools.explainQuery",
					"when": "pgsqlToolsActive"
				},
				{
					"command": "pgsql-tools.configureGitRepository",
					"when": "pgsqlToolsActive"
				},
				{
					"command": "pgsql-tools.refreshGitStatus",
					"when": "pgsqlToolsActive"
				},
				{
					"command": "pgsql-tools.showGitDdlDiff",
					"when": "pgsqlToolsActive"
				},
				{
					"command": "pgsql-tools.syncGitDdlFromDatabase",
					"when": "pgsqlToolsActive"
				}
			]
		},
		"keybindings": [
			{
				"command": "pgsql-tools.executeSqlFile",
				"key": "F9",
				"when": "editorTextFocus && editorLangId == sql"
			},
			{
				"command": "pgsql-tools.executeSqlFile",
				"key": "ctrl+shift+e",
				"mac": "cmd+shift+e",
				"when": "editorTextFocus && editorLangId == sql"
			},
			{
				"command": "pgsql-tools.explainQuery",
				"key": "ctrl+shift+x",
				"mac": "cmd+shift+x",
				"when": "editorTextFocus && editorLangId == sql"
			},
			{
				"command": "pgsql-tools.searchTree",
				"key": "ctrl+f",
				"mac": "cmd+f",
				"when": "focusedView == pgsqlDatabases"
			},
			{
				"command": "pgsql-tools.showHealth",
				"key": "ctrl+shift+h",
				"mac": "cmd+shift+h",
				"when": "pgsqlToolsActive"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"package": "vsce package",
		"copy:codicons": "node -e \"const fs=require('fs');const d='resources/fonts';fs.mkdirSync(d,{recursive:true});fs.copyFileSync('node_modules/@vscode/codicons/dist/codicon.ttf',d+'/codicon.ttf');\"",
		"compile": "tsc -p ./ && npm run copy:codicons",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"lint": "eslint src --ext ts"
	},
	"devDependencies": {
		"@types/node": "^18.0.0",
		"@types/pg": "^8.10.0",
		"@types/ssh2": "^1.15.5",
		"@types/vscode": "^1.75.0",
		"@typescript-eslint/eslint-plugin": "^5.48.0",
		"@typescript-eslint/parser": "^5.48.0",
		"eslint": "^8.31.0",
		"typescript": "^4.9.4"
	},
	"dependencies": {
		"@vscode/codicons": "^0.0.45",
		"pg": "^8.11.0",
		"ssh2": "^1.17.0"
	}
}
